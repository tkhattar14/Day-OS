# Focus App — Environment Variables
# Copy this to .env and fill in your keys

# TTS: ElevenLabs (optional — leave empty to disable voice output)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE=

# STT: OpenAI Whisper (optional — leave empty to disable voice input)
OPENAI_API_KEY=

# Webhook: Forward voice messages to an external service (optional)
# Set these if you want voice input to trigger an AI assistant
HOOKS_TOKEN=
GATEWAY_PORT=18789
